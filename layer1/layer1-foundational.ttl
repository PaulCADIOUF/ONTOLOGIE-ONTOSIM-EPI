<http://purl.obolibrary.org/obo/RO_0000086> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <http://purl.obolibrary.org/obo/RO_0000053> ;
                                            rdfs:range <http://purl.obolibrary.org/obo/BFO_0000019> ;
                                            rdfs:comment "SimulationModel → paramètres épidémiologiques"@fr ,
                                                         "a relation between an independent continuant (the bearer) and a quality, in which the quality specifically depends on the bearer for its existence"@en ;
