###  http://purl.obolibrary.org/obo/RO_0001025
<http://purl.obolibrary.org/obo/RO_0001025> rdf:type owl:ObjectProperty ;
                                            rdfs:comment "Population → région géographique (ContextKnowledge)"@fr ,
                                                         "a relation between two independent continuants, the target and the location, in which the target is entirely within the location"@en ;
                                            rdfs:label "located in"@en ;
                                            rdfs:seeAlso "http://purl.obolibrary.org/obo/ro.owl" .


###  http://purl.obolibrary.org/obo/RO_0002233
<http://purl.obolibrary.org/obo/RO_0002233> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <http://purl.obolibrary.org/obo/RO_0000057> ;
                                            rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000015> ;
                                            rdfs:comment "RecompositionProcess → modèles sources (DK, CK, MSK, EK)"@fr ,
                                                         "p has input c iff: p is a process, c is a material entity, c is a participant in p, c is present at the start of p, and the state of c is modified during p."@en ;
                                            rdfs:label "has input"@en ;
                                            rdfs:seeAlso "http://purl.obolibrary.org/obo/ro.owl" .


###  http://purl.obolibrary.org/obo/RO_0002234
<http://purl.obolibrary.org/obo/RO_0002234> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <http://purl.obolibrary.org/obo/RO_0000057> ;
                                            rdfs:comment "RecompositionProcess → nouveau modèle généré"@fr ,
                                                         """p has output c iff c is a participant in p, c is present at the end of p, and c is not present at the beginning of p.

p has output c iff c is a participant in p, c is present at the end of p, and c is not present in the same state at the beginning of p."""@en ;
                                            rdfs:label "has output"@en ;
                                            rdfs:seeAlso "http://purl.obolibrary.org/obo/ro.owl" .


